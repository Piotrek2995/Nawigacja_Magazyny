<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        PoC: aplikacja komunikuje sie z backendem po HTTP (cleartext) w sieci lokalnej.
        Adres IP hosta jest dynamiczny (zmienia sie miedzy sesjami), dlatego zezwalamy
        na cleartext globalnie, zamiast utrzymywac liste konkretnych IP - ktora i tak
        trzeba bylo recznie aktualizowac przy kazdej zmianie sieci.

        UWAGA: w wersji produkcyjnej nalezy uzywac HTTPS i usunac to zezwolenie
        (cleartextTrafficPermitted="false" + ruch tylko po TLS).
    -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
